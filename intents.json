{
  "intents": [
    {
      "tag": "greeting",
      "patterns": ["hi", "hello", "hey", "hi there", "hello bot"],
      "responses": ["Hello!", "Hi there!", "Hey! How can I help you?"]
    },
    {
      "tag": "name",
      "patterns": ["who are you", "what is your name", "hu r u", "your name"],
      "responses": ["I am your AI chatbot"]
    },
    {
      "tag": "speak",
      "patterns": ["can you speak", "can you talk", "do you speak"],
      "responses": ["Yes, I can speak!", "Of course I can talk"]
    },
    {
      "tag": "set_name",
      "patterns": ["call me", "my name is", "i am", "instead of ra call me"],
      "responses": ["Okay, I will remember your name"]
    },
    {
      "tag": "get_name",
      "patterns": ["who am i", "what is my name"],
      "responses": ["Your name is"]
    },
    {
      "tag": "goodbye",
      "patterns": ["bye", "exit", "quit"],
      "responses": ["Bye!", "See you soon!"]
    }
  ]
}
